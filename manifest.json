{
  "manifest_version": 3,
  "name": "Siri-Gemini Action Simulator",
  "description": "A WWDC26 concept extension: current page context, Gemini planning, safe preview, and user-approved browser actions.",
  "version": "1.0.0",
  "permissions": ["activeTab", "scripting", "storage", "tabs", "clipboardWrite"],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://openrouter.ai/*",
    "<all_urls>"
  ],
  "icons": {
    "32": "icons/apple32.png",
    "128": "icons/apple128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "32": "icons/apple32.png",
      "128": "icons/apple128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
